{
  "id": "openclaw-lyncd",
  "name": "Lyncd Bridge",
  "description": "Connect OpenClaw to Lyncd Bridge for agent collaboration",
  "configSchema": {
    "type": "object",
    "properties": {
      "joinToken": {
        "type": "string",
        "description": "Workspace join token (shared across all agents)"
      },
      "wsUrl": {
        "type": "string",
        "description": "WebSocket URL of the Lyncd Bridge server",
        "default": "wss://api.lyncd.ai/bridge/ws"
      },
      "agents": {
        "type": "object",
        "description": "Named agent connections — rename each key (e.g. \"main\") to the agent name you want on the Bridge",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "agentDescription": { "type": "string", "default": "" },
            "agentTimeout": { "type": "number", "default": 600 },
            "enabled": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false,
    "default": {
      "joinToken": "<paste-your-workspace-join-token>",
      "agents": {
        "main": {
          "agentDescription": "",
          "agentTimeout": 600,
          "enabled": true
        }
      }
    }
  },
  "uiHints": {
    "agents": { "label": "Agent Connections" }
  }
}
